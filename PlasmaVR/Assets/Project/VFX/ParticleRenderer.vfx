  m_Script: {fileID: 11500000, guid: 833c3541f2af4b28b080abc2cd1a804d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.VisualEffectGraph.Editor::UnityEditor.VFX.Block.CustomHLSL
  m_UIIgnoredErrors: []
  m_Parent: {fileID: 8926484042661614611}
  m_Children: []
  m_UIPosition: {x: 0, y: 0}
  m_UICollapsed: 0
  m_UISuperCollapsed: 0
  m_InputSlots:
  - {fileID: 8926484042661614995}
  - {fileID: 8926484042661614946}
  - {fileID: 8926484042661614974}
  - {fileID: 8926484042661614978}
  - {fileID: 8926484042661615040}
  - {fileID: 8926484042661615044}
  - {fileID: 8926484042661615048}
  - {fileID: 8926484042661614982}
  - {fileID: 8926484042661614986}
  - {fileID: 8926484042661615052}
  - {fileID: 8926484042661615056}
  - {fileID: 8926484042661615060}
  m_OutputSlots: []
  m_Disabled: 0
  m_ActivationSlot: {fileID: 8926484042661614887}
  m_BlockName: Clip Kill
  m_HLSLCode: "void CustomHLSL(inout VFXAttributes attributes,\r\n               
    in float enabled,\r\n                in float3 positionWS,\r\n               
    in float3 ClipBoxCenter1, in float3 ClipBoxSize1,\r\n                in float3
    ClipBoxInvRotRow0_1, in float3 ClipBoxInvRotRow1_1, in float3 ClipBoxInvRotRow2_1,\r\n               
    in float3 ClipBoxCenter2, in float3 ClipBoxSize2,\r\n                in float3
    ClipBoxInvRotRow0_2, in float3 ClipBoxInvRotRow1_2, in float3 ClipBoxInvRotRow2_2)\r\n{\r\n   
    if (enabled == 0) return;\r\n\r\n    // Box 1\r\n    {\r\n        float3 rel
    = positionWS - ClipBoxCenter1;\r\n        float3 local = float3(\r\n           
    dot(rel, ClipBoxInvRotRow0_1),\r\n            dot(rel, ClipBoxInvRotRow1_1),\r\n           
    dot(rel, ClipBoxInvRotRow2_1)\r\n        );\r\n        float3 half = ClipBoxSize1
    * 0.5;\r\n        if (abs(local.x) < half.x && abs(local.y) < half.y && abs(local.z)
    < half.z)\r\n        { attributes.alive = false; return; }\r\n    }\r\n\r\n   
    // Box 2\r\n    {\r\n        float3 rel = positionWS - ClipBoxCenter2;\r\n       
    float3 local = float3(\r\n            dot(rel, ClipBoxInvRotRow0_2),\r\n           
    dot(rel, ClipBoxInvRotRow1_2),\r\n            dot(rel, ClipBoxInvRotRow2_2)\r\n       
    );\r\n        float3 half = ClipBoxSize2 * 0.5;\r\n        if (abs(local.x) <
    half.x && abs(local.y) < half.y && abs(local.z) < half.z)\r\n        { attributes.alive
    = false; }\r\n    }\r\n}"
  m_ShaderFile: {fileID: 0}
  m_AvailableFunction:
    selection: CustomHLSL
    selectedIndex: 0
